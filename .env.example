# Optional. Set a server-side Anthropic API key to offer keyless runs.
# Leave unset to require bring-your-own-key in the UI.
ANTHROPIC_API_KEY=

# Optional. When set, keyless runs require this shared access code
# (the UI has an "access code" field). Strongly recommended whenever
# ANTHROPIC_API_KEY is set — the public URL is scannable.
FRIENDS_CODE=

# Free keyless runs per IP per day. Default: 3.
FREE_RUNS_PER_DAY=3

# Free keyless runs per day across ALL visitors (global cost ceiling).
# Default: 25.
FREE_RUNS_GLOBAL_PER_DAY=25
